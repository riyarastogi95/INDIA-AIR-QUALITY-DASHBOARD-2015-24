      <aliases enabled='yes' />
      <column caption='AQI Bucket' datatype='string' name='[AQI_Bucket]' role='dimension' type='nominal' />
      <column caption='AQI Outlier Flag' datatype='integer' name='[AQI_Outlier_Flag]' role='measure' type='quantitative' />
      <column caption='year_num' datatype='integer' name='[Calculation_0207797237927936]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='Year([Date])' />
      </column>
      <column caption='% Emergency Days' datatype='real' name='[Calculation_0207797241196545]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [AQI] &gt; 300 THEN 1 ELSE 0 END) / COUNT([AQI]) * 100' />
      </column>
      <column caption='AQI Status' datatype='string' name='[Calculation_0207797241479170]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([AQI]) &gt; 200 THEN &quot;🔴 Critical&quot;&#10;ELSEIF AVG([AQI]) &gt; 100 THEN &quot;🟡 Concerning&quot;&#10;ELSE &quot;🟢 Acceptable&quot;&#10;END' />
      </column>
      <column caption='COVID Impact' datatype='string' name='[Calculation_0207797241614339]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF YEAR([Date]) &lt; 2020 THEN &quot;Pre-COVID&quot;&#10;ELSEIF YEAR([Date]) = 2020 THEN &quot;COVID (2020)&quot;&#10;ELSE &quot;Post-COVID&quot;&#10;END' />
      </column>
      <column caption='Worst city' datatype='real' name='[Calculation_0207797251612677]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX({ FIXED [City] : AVG([AQI]) }) }' />
      </column>
      <column caption='Best City' datatype='real' name='[Calculation_0207797253054470]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX({ FIXED [City] : AVG([AQI]) }) }' />
